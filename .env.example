# Copy to .env for local development.
#
# AWS credentials: on a host with a mounted ~/.aws profile, leave the three
# AWS_* credential lines below commented out — boto3 uses your profile.
# On a VM or plain local box WITHOUT a host profile, uncomment them so the
# Docker container receives real credentials (see AUTHENTICATION.md).
AWS_REGION=us-east-1

# VM / Local only — uncomment and fill when no ~/.aws profile is available.
# AWS_SESSION_TOKEN is required only for temporary (STS/SSO) credentials.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

GLUE_DATABASE=trailwhisperer_db
GLUE_TABLE=cloudtrail_logs
ATHENA_WORKGROUP=primary
# Where Athena writes query results. Required for local dev against the default
# `primary` workgroup (it has no output location). Deployed workgroups enforce
# their own, so leave this unset in AWS. Example: s3://my-athena-results/results/
# ATHENA_OUTPUT_LOCATION=s3://YOUR-BUCKET/results/
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BYTES_SCANNED_CUTOFF=1073741824
ALLOWED_TIME_RANGE_MAX_DAYS=90
AUTH_TOKEN=local-dev-token
